# ============================================
# REQUIRED - Supabase
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# REQUIRED - SumUp Cloud API
# Get these from: https://developer.sumup.com/
# ============================================
SUMUP_API_KEY=your-sumup-api-key-here
SUMUP_MERCHANT_CODE=MXXXXXXXXX
SUMUP_CLIENT_ID=your-client-id
SUMUP_CLIENT_SECRET=your-client-secret

# Optional - only needed if using OAuth flow
NEXT_PUBLIC_SUMUP_CLIENT_ID=your-client-id
SUMUP_REDIRECT_URI=https://your-app.vercel.app/api/auth/sumup/callback

# SumUp Affiliate Key (required for checkout requests per Cloud API docs)
SUMUP_AFFILIATE_KEY=your-affiliate-key

# Webhook secret for verifying SumUp webhook payloads
SUMUP_WEBHOOK_SECRET=your-webhook-secret

# Leave this blank - defaults to https://api.sumup.com
SUMUP_API_BASE=

# ============================================
# OPTIONAL - App URL (used for redirects)
# ============================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================
# OPTIONAL - Cloudflare R2 (item image uploads)
# ============================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# ============================================
# OPTIONAL - Upstash Redis (rate limiting)
# Leave blank to use no-op (development mode)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# OPTIONAL - Perks integration
# ============================================
PERKS_API_KEY=

# ============================================
# Email (Resend) - for vouchers + receipts
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@rewards.penkey.co.uk
RESEND_REPLY_TO_EMAIL=nfdrepairs@gmail.com

# ============================================
# Database Backup (daily email via Resend)
# Generate a random secret and set it here + in cron-job.org
# ============================================
BACKUP_SECRET=generate-a-random-string-here
BACKUP_EMAIL=nfdrepairs@gmail.com
