{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputsMode": "new-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputsMode": "new-only"
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputsMode": "new-only"
    },
    "clean": {
      "cache": false
    }
  }
}
